# ============================================================
# .env.example — WATCH-ME Intelligent Security System
# ------------------------------------------------------------
# Copy this to .env for local development (never upload .env)
# On Render: add these under Environment Variables tab
# ============================================================

# ── Server ─────────────────────────────────────────────────────
PORT=8000
# Your deployed frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.onrender.com

# ── Supabase PostgreSQL ─────────────────────────────────────────
# Get from: Supabase Dashboard → Project → Settings → Database
# Copy the "Connection string" URI (Transaction pooler recommended)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Supabase API (for email confirmation) ──────────────────────
# Get from: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...  # Service role key (keep secret!)

# ── JWT Security ────────────────────────────────────────────────
# Generate at: https://randomkeygen.com → Fort Knox Passwords
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-characters

# ── Telegram Bot (optional) ────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# ── Twilio SMS (optional) ──────────────────────────────────────
# Get from https://twilio.com → Console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
