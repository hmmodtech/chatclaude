
# ============================================================
# .env.example — Gaza Security Dashboard Backend
# ------------------------------------------------------------
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to: .env
#   2. Fill in your real values (never share the .env file)
#   3. On Render: add these as Environment Variables in the dashboard
#      (Render Dashboard → Your Service → Environment tab)
# ============================================================

# ── Server ────────────────────────────────────────────────────
# Render sets PORT automatically — leave as-is
PORT=8000

# The URL of your deployed frontend (used for CORS whitelist)
# Example: https://gaza-dashboard.onrender.com
FRONTEND_URL=http://localhost:3000

# ── Telegram Bot (optional — for real Telegram alerts) ────────
# Steps to get this:
#   1. Open Telegram → search for @BotFather
#   2. Send: /newbot
#   3. Follow the instructions
#   4. Copy the token you receive (looks like: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=

# ── Twilio SMS (optional — for real SMS alerts) ───────────────
# Steps to get this:
#   1. Sign up free at https://twilio.com
#   2. Go to Console → Account Info
#   3. Copy Account SID, Auth Token
#   4. Get a free Twilio phone number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── WhatsApp Business API (optional) ──────────────────────────
# If you want server-side WhatsApp (not just wa.me links):
# Sign up at https://ultramsg.com and get:
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

# ── Security ──────────────────────────────────────────────────
# A random secret key for signing tokens
# Generate one at: https://randomkeygen.com (use "Fort Knox Passwords")
SECRET_KEY=change-this-to-a-random-string-minimum-32-chars
